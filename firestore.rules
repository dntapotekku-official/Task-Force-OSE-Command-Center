rules_version = '2';

// =====================================================================
// APOTEKKU — Task Force OSE Command Center
// Aturan akses Cloud Firestore
//
// KONTEKS PENTING:
// Aplikasi ini belum memakai Firebase Authentication. Login username/password
// dijalankan di sisi browser, sehingga Firestore TIDAK BISA mengenali siapa
// yang menulis. Karena itu aturan di bawah hanya bisa membatasi BENTUK data,
// bukan SIAPA penulisnya.
//
// Pilih salah satu opsi di bawah sesuai kebutuhan Anda saat ini.
// =====================================================================


// ---------------------------------------------------------------------
// OPSI A — SEMENTARA (dipakai sekarang, tanpa Firebase Auth)
// Lebih aman dari "allow read, write: if true" karena:
//   - hanya mengizinkan path aplikasi ini (bukan seluruh database)
//   - menolak dokumen berukuran tidak wajar (mencegah abuse/spam)
//   - membatasi nama sub-koleksi yang boleh ditulis
// Batasannya: siapa pun yang tahu URL & config tetap bisa baca/tulis.
// Gunakan hanya sampai Opsi B siap.
// ---------------------------------------------------------------------
service cloud.firestore {
  match /databases/{database}/documents {

    // Root dokumen aplikasi
    match /commandCenter/app {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['meta', 'kpiTargets', 'schema']);

      // Sub-koleksi yang dikenali aplikasi
      match /{sub}/{docId} {
        allow read: if true;
        allow write: if sub in ['items', 'audits', 'users', 'acts', 'kpiEntries', 'reviewData', 'integrations']
                     && request.resource.data.size() < 60;
        allow delete: if sub in ['items', 'audits', 'users', 'acts', 'kpiEntries', 'reviewData', 'integrations'];
      }
    }

    // Tolak seluruh path lain
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


// =====================================================================
// OPSI B — TARGET AKHIR (setelah memakai Firebase Authentication)
//
// Langkah yang perlu dilakukan lebih dulu:
//   1. Firebase Console → Authentication → aktifkan "Email/Password"
//      (username outlet dipetakan jadi email teknis, contoh:
//       apotekku-kamasan@apotekku.internal)
//   2. Buat 1 dokumen profil per user di koleksi /profiles/{uid} berisi:
//        { role: "admin" | "ssc" | "outlet", divisi: "OPS|QIC|HGPGA", outlet: "APOTEKKU ..." }
//      Dokumen ini HANYA boleh ditulis dari Firebase Console / Admin SDK.
//   3. Ganti aturan di bawah menjadi aktif (hapus komentar), lalu hapus Opsi A.
//
// Dengan Opsi B, pembatasan peran menjadi NYATA di database:
// outlet benar-benar tidak bisa menulis data outlet lain, meski lewat kode.
